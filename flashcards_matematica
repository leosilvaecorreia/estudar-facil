// ── banco infinito de perguntas ──
function gerarBancoTabuada() {
  const itens = [];
  for (let a = 2; a <= 10; a++) {
    for (let b = 1; b <= 10; b++) {
      const res = a * b;
      itens.push({ texto:`${a} × ${b} = ${res}`, correto:true,  exp:`${a} × ${b} = ${res}` });
      // errado: resultado vizinho
      const delta = (Math.random()<.5?1:-1)*(Math.floor(Math.random()*3)+1);
      const err = res + delta;
      if (err > 0)
        itens.push({ texto:`${a} × ${b} = ${err}`, correto:false, exp:`${a} × ${b} = ${res}, não ${err}` });
    }
  }
  return itens;
}

function gerarBancoRomanos() {
  const pares = [
    [1,'I'],[2,'II'],[3,'III'],[4,'IV'],[5,'V'],[6,'VI'],[7,'VII'],[8,'VIII'],[9,'IX'],
    [10,'X'],[14,'XIV'],[19,'XIX'],[20,'XX'],[40,'XL'],[50,'L'],
    [90,'XC'],[100,'C'],[400,'CD'],[500,'D'],[900,'CM'],[1000,'M']
  ];
  const itens = [];
  for (const [val, sim] of pares) {
    itens.push({ texto:`${val} = ${sim}`, correto:true,  exp:`${val} em romano é ${sim}` });
    const outro = pares.filter(x=>x[1]!==sim)[Math.floor(Math.random()*(pares.length-1))];
    itens.push({ texto:`${val} = ${outro[1]}`, correto:false, exp:`${val} em romano é ${sim}, não ${outro[1]}` });
  }
  return itens;
}

function embaralhar(arr){
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}
  return a;
}

function validarConfig(){
  const ok=document.getElementById('chk-tabuada').checked||document.getElementById('chk-romanos').checked;
  document.getElementById('btn-comecar').disabled=!ok;
}

// ── velocidade gradativa: começa em 7s, reduz 0.3s a cada acerto, mínimo 1.2s
function calcVelocidade(acertos) {
  const dur = Math.max(1.2, 7 - acertos * 0.3);
  let label;
  if (dur > 5.5)     label = '🟢 Devagar';
  else if (dur > 3.8)label = '🟡 Médio';
  else if (dur > 2.5)label = '🟠 Rápido';
  else if (dur > 1.7)label = '🔴 Veloz';
  else               label = '⚡ Turbo!';
  return { dur: Math.round(dur * 100) / 100, label };
}

// ── estado global ──
let banco=[], acertos=0, erros=[], errosTotal=0;
let timerJogo=null;
let segundosRestantes=60;
let jogando=false;
const MAX_ERROS=5;
const AMORTECEDOR=2; // acertos que volta ao errar

function gerarBanco(){
  const usaTab=document.getElementById('chk-tabuada')?.checked;
  const usaRom=document.getElementById('chk-romanos')?.checked;
  let b=[];
  if(usaTab) b=[...b,...gerarBancoTabuada()];
  if(usaRom) b=[...b,...gerarBancoRomanos()];
  return embaralhar(b);
}

function gerarBancoAtual(){
  banco=gerarBanco();
}

// id único por pergunta para evitar race conditions
let perguntaAtualId = 0;

function iniciarQuiz(){
  gerarBancoAtual();
  acertos=0; erros=[]; errosTotal=0; segundosRestantes=60; jogando=true; perguntaAtualId=0;

  document.getElementById('quiz-config').style.display='none';
  document.getElementById('quiz-arena-wrap').style.display='block';
  document.getElementById('quiz-resultado').innerHTML='';

  // limpa trilho para garantir
  document.getElementById('trilho').innerHTML='';
  document.getElementById('arena-acertos').textContent='0';
  atualizarVidas();
  const el=document.getElementById('arena-cronometro');
  el.textContent='60'; el.classList.remove('urgente');

  clearInterval(timerJogo);
  timerJogo=setInterval(()=>{
    segundosRestantes--;
    const el=document.getElementById('arena-cronometro');
    if(el){
      el.textContent=segundosRestantes;
      if(segundosRestantes<=10) el.classList.add('urgente');
    }
    if(segundosRestantes<=0){
      clearInterval(timerJogo);
      encerrarJogo();
    }
  },1000);

  lancarPergunta();
}

function encerrarJogo(){
  jogando=false;
  perguntaAtualId++; // invalida qualquer pergunta em andamento
  // para animação: limpa o trilho
  const trilho=document.getElementById('trilho');
  if(trilho) trilho.innerHTML='';
  // desabilita botões
  const bc=document.getElementById('btn-certo');
  const be=document.getElementById('btn-errado');
  if(bc) bc.disabled=true;
  if(be) be.disabled=true;
  setTimeout(()=>mostrarResultado(errosTotal>=MAX_ERROS), 300);
}

function atualizarVidas(){
  const restantes = MAX_ERROS - errosTotal;
  const el = document.getElementById('arena-vidas');
  if(el) el.textContent = '❤️'.repeat(Math.max(0,restantes)) + '🖤'.repeat(Math.min(errosTotal,MAX_ERROS));
}

function mostrarConfig(){
  voltarConfig();
}

function lancarPergunta(){
  if(!jogando) return;
  if(!banco.length) banco=gerarBanco();

  const q=banco.pop();
  const vel=calcVelocidade(acertos);
  const meuId = ++perguntaAtualId; // id único desta pergunta

  // atualiza UI
  document.getElementById('arena-acertos').textContent=acertos;
  document.getElementById('arena-velocidade').textContent=vel.label;
  document.getElementById('btn-certo').disabled=false;
  document.getElementById('btn-errado').disabled=false;
  document.getElementById('arena-feedback').className='arena-feedback';

  // animação da operação no trilho
  const trilho=document.getElementById('trilho');
  trilho.innerHTML='';
  const tag=document.createElement('div');
  tag.className='operacao-tag';
  tag.textContent=q.texto;
  tag.style.animationDuration=vel.dur+'s';
  trilho.appendChild(tag);
  trilho._q=q;

  // ao terminar a animação sem resposta = erro, só se ainda for a mesma pergunta
  tag.addEventListener('animationend', ()=>{
    if(!jogando || perguntaAtualId!==meuId) return;
    if(!document.getElementById('btn-certo').disabled){
      document.getElementById('btn-certo').disabled=true;
      document.getElementById('btn-errado').disabled=true;
      registrarResposta(null, true, meuId);
    }
  });
}

function responder(achou){
  if(!jogando) return;
  document.getElementById('btn-certo').disabled=true;
  document.getElementById('btn-errado').disabled=true;
  registrarResposta(achou, false, perguntaAtualId);
}

function registrarResposta(achou, timeout, idEsperado){
  // ignora se já mudou de pergunta ou jogo acabou
  if(perguntaAtualId!==idEsperado) return;

  const q=document.getElementById('trilho')._q;
  if(!q) return;
  const fb=document.getElementById('arena-feedback');

  if(timeout){
    fb.textContent='⏰'; fb.className='arena-feedback erro show';
    erros.push(q);
    errosTotal++;
    acertos = Math.max(0, acertos - AMORTECEDOR);
    document.getElementById('arena-velocidade').textContent=calcVelocidade(acertos).label;
    atualizarVidas();
    if(errosTotal>=MAX_ERROS){
      clearInterval(timerJogo);
      encerrarJogo();
      return;
    }
  } else {
    const ganhou=(achou===q.correto);
    if(ganhou){
      acertos++;
      fb.textContent=['🎉','⭐','🔥','💥','✨','👏'][Math.floor(Math.random()*6)];
      fb.className='arena-feedback acerto show';
      document.getElementById('arena-acertos').textContent=acertos;
      // atualiza velocidade imediatamente ao acertar
      const novaVel=calcVelocidade(acertos);
      document.getElementById('arena-velocidade').textContent=novaVel.label;
    } else {
      fb.textContent='❌'; fb.className='arena-feedback erro show';
      erros.push(q);
      errosTotal++;
      // amortecedor: volta AMORTECEDOR acertos na velocidade
      acertos = Math.max(0, acertos - AMORTECEDOR);
      document.getElementById('arena-velocidade').textContent=calcVelocidade(acertos).label;
      atualizarVidas();
      if(errosTotal>=MAX_ERROS){
        clearInterval(timerJogo);
        encerrarJogo();
        return;
      }
    }
  }
  if(jogando) setTimeout(()=>{ if(jogando) lancarPergunta(); }, 120);
}

function mostrarResultado(porErros=false){
  document.getElementById('quiz-arena-wrap').style.display='none';
  const total=acertos+erros.length;
  const pct=total>0?Math.round(acertos/total*100):0;
  let emoji='🌟', msg='Incrível! Você é fera na Matemática!';
  if(acertos<5){emoji='💪';msg='Continue praticando — você vai melhorar!';}
  else if(acertos<10){emoji='😊';msg='Bom trabalho! Tenta de novo para bater o recorde.';}
  else if(acertos<15){emoji='🎉';msg='Muito bem! Você está mandando bem!';}
  else if(acertos<20){emoji='🏆';msg='Excelente! Você é rápido!';}
  else{emoji='🚀';msg='UAU! Você é um gênio da matemática!';}

  const velFinal=calcVelocidade(acertos);
  const vistas=new Set();
  const unicas=erros.filter(q=>{if(vistas.has(q.texto))return false;vistas.add(q.texto);return true;}).slice(0,8);
  const revisao=unicas.length>0
    ?`<div class="revisao-titulo">📖 Revise estas aqui:</div>`
      +unicas.map(q=>`<div class="revisao-card"><b>${q.texto}</b> — ${q.exp}</div>`).join('')
    :`<div style="color:#06D6A0;font-weight:800;font-size:1rem;margin-top:8px">🏆 Zero erros! Perfeito!</div>`;

  document.getElementById('quiz-resultado').innerHTML=`
    <div class="resultado-shell">
      <div class="resultado-emoji">${emoji}</div>
      <div class="resultado-titulo">${msg}</div>
      <div class="resultado-placar">${acertos}<span style="font-size:1.4rem;color:#bbb"> acertos</span></div>
      <div class="resultado-sub">${porErros?'💔 5 erros — fim de jogo!':'⏱️ Tempo esgotado!'} · velocidade final: ${velFinal.label}</div>
      <button class="btn-reiniciar" onclick="voltarConfig()">🔄 Jogar de novo</button>
      ${revisao}
    </div>`;
}

function voltarConfig(){
  clearInterval(timerJogo);
  jogando=false;
  document.getElementById('quiz-resultado').innerHTML='';
  document.getElementById('quiz-arena-wrap').style.display='none';
  document.getElementById('quiz-config').style.display='block';
  // reseta cronômetro visual
  const el=document.getElementById('arena-cronometro');
  if(el){el.textContent='⏱️ 60s';el.classList.remove('urgente');}
}

