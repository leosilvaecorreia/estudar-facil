<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flash Cards de Matemática</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --amarelo: #FFD93D;
    --laranja: #FF6B35;
    --verde:   #06D6A0;
    --azul:    #118AB2;
    --roxo:    #845EC2;
    --rosa:    #FF6B9D;
    --bg:      #FFFBF0;
    --dark:    #1A1A2E;
    --tab1:    #FF6B35;
    --tab2:    #118AB2;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Nunito', sans-serif; background: var(--bg); min-height: 100vh; overflow-x: hidden; }

  /* ── BOTÃO HOME ── */
  .btn-home {
    position: fixed; top: 14px; left: 14px;
    background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.2);
    color: rgba(255,255,255,.7); font-family: 'Nunito', sans-serif;
    font-weight: 800; font-size: .8rem; padding: 6px 14px;
    border-radius: 50px; cursor: pointer; text-decoration: none;
    display: flex; align-items: center; gap: 5px; z-index: 999;
    transition: background .2s, color .2s;
  }
  .btn-home:hover { background: rgba(255,255,255,.18); color: white; }

  /* ── HEADER ── */
  header {
    background: var(--dark); padding: 18px 24px 14px;
    text-align: center; position: relative; overflow: hidden;
  }
  header::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(45deg, transparent, transparent 20px,
      rgba(255,255,255,.03) 20px, rgba(255,255,255,.03) 40px);
  }
  header h1 {
    font-family: 'Fredoka One', cursive; font-size: 2rem;
    color: var(--amarelo); letter-spacing: 1px; position: relative;
  }
  header p { color: rgba(255,255,255,.55); font-size: .88rem; margin-top: 4px; position: relative; }

  /* ── TABS ── */
  .tabs { display: flex; justify-content: center; gap: 8px; padding: 20px 16px 0; flex-wrap: wrap; }
  .tab-btn {
    font-family: 'Fredoka One', cursive; font-size: 1rem;
    padding: 10px 20px; border: 3px solid transparent;
    border-radius: 50px; cursor: pointer; transition: all .2s;
    background: white; color: var(--dark); box-shadow: 0 3px 0 rgba(0,0,0,.12);
  }
  .tab-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 0 rgba(0,0,0,.12); }
  .tab-btn.active { color: white; transform: translateY(-2px); }
  .tab-btn[data-tab="tabuada"].active  { background: var(--tab1); border-color: var(--tab1); }
  .tab-btn[data-tab="romanos"].active  { background: var(--tab2); border-color: var(--tab2); }
  .tab-btn[data-tab="quiz"].active     { background: var(--roxo); border-color: var(--roxo); }
  .tab-btn[data-tab="resumo"].active   { background: #555; border-color: #555; }

  /* ── SECTIONS ── */
  .section { display: none; padding: 24px 16px 40px; max-width: 900px; margin: 0 auto; }
  .section.active { display: block; animation: fadeIn .3s ease; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }

  .sec-title {
    font-family: 'Fredoka One', cursive; font-size: 1.5rem;
    margin-bottom: 20px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .sec-badge {
    display: inline-block; padding: 4px 14px; border-radius: 50px;
    font-size: .85rem; color: white; font-family: 'Nunito', sans-serif; font-weight: 700;
  }

  /* ── DICA CARD ── */
  .dica-card {
    background: var(--dark); border-radius: 20px;
    padding: 20px 22px; margin-top: 20px; box-shadow: 0 6px 0 rgba(0,0,0,.2);
  }
  .dica-card h3 { font-family: 'Fredoka One', cursive; color: var(--amarelo); font-size: 1.1rem; margin-bottom: 12px; }
  .dica-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
  .dica-item {
    background: rgba(255,255,255,.07); border-radius: 12px;
    padding: 12px 14px; color: rgba(255,255,255,.88); font-size: .88rem; line-height: 1.6;
  }
  .dica-item strong { display: block; color: var(--amarelo); font-family: 'Fredoka One', cursive; font-size: 1rem; margin-bottom: 4px; }

  /* ════════════════════════
     TABUADA — cards por número
  ════════════════════════ */
  .tabuadas-scroll {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    margin-bottom: 24px;
  }
  .tabuada-card {
    background: white; border-radius: 22px;
    padding: 22px 18px; box-shadow: 0 5px 0 rgba(0,0,0,.09);
    border-top: 6px solid;
  }
  .tabuada-card-titulo {
    font-family: 'Fredoka One', cursive; font-size: 1.4rem;
    text-align: center; margin-bottom: 14px;
  }
  .tab-linha {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    padding: 6px 10px; border-radius: 10px;
    font-size: .95rem; font-weight: 800; margin-bottom: 4px;
  }
  .tab-linha .op { color: rgba(0,0,0,.4); font-size: .9rem; }
  .tab-linha .res { font-family: 'Fredoka One', cursive; font-size: 1.1rem; }

  /* macetes section */
  .macetes-section {
    margin-top: 10px;
  }
  .macete-box {
    background: white; border-radius: 18px;
    padding: 18px 20px; border-left: 5px solid;
    margin-bottom: 14px; box-shadow: 0 3px 0 rgba(0,0,0,.07);
  }
  .macete-box h4 { font-family: 'Fredoka One', cursive; font-size: 1.05rem; margin-bottom: 8px; }
  .macete-box p { font-size: .9rem; line-height: 1.6; font-weight: 700; color: #444; }
  .macete-box .ex {
    display: inline-block; margin-top: 8px; margin-right: 6px;
    border-radius: 8px; padding: 4px 12px; font-size: .88rem; font-weight: 800;
  }

  /* ════════════════════════
     ALGARISMOS ROMANOS — card grande
  ════════════════════════ */
  .romano-grande {
    background: white; border-radius: 22px;
    padding: 28px 24px; box-shadow: 0 6px 0 rgba(0,0,0,.09);
    margin-bottom: 20px;
  }
  .romano-grande h3 {
    font-family: 'Fredoka One', cursive; font-size: 1.1rem;
    color: var(--tab2); margin: 18px 0 10px; border-bottom: 2px solid #f0f0f0; padding-bottom: 6px;
  }
  .romano-grande h3:first-child { margin-top: 0; }
  .romanos-linha {
    display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
  }
  .romano-item {
    display: flex; flex-direction: column; align-items: center;
    background: #f8f8ff; border-radius: 12px;
    padding: 10px 14px; min-width: 70px;
    border-bottom: 3px solid var(--tab2);
    transition: transform .15s;
  }
  .romano-item:hover { transform: translateY(-3px); }

  .romano-item .r-sim {
    font-family: 'Fredoka One', cursive; font-size: 1.3rem; color: var(--tab2); line-height: 1;
  }
  .romano-item .r-val {
    font-size: .75rem; font-weight: 800; color: #999; margin-top: 4px;
  }

  /* ════════════════════════
     QUIZ
  ════════════════════════ */
  .quiz-shell { background: white; border-radius: 24px; padding: 28px 24px; box-shadow: 0 6px 0 rgba(0,0,0,.08); }
  .prog-bar-wrap { background: #eee; border-radius: 50px; height: 10px; margin-bottom: 6px; overflow: hidden; }
  .prog-bar-fill { height: 100%; border-radius: 50px; background: linear-gradient(90deg, var(--tab1), var(--tab2)); transition: width .4s ease; }
  .prog-label { font-size:.82rem; color:#aaa; font-weight:700; text-align:right; margin-bottom:20px; }
  .score-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
  .score-pill { background: var(--dark); color: var(--amarelo); font-family:'Fredoka One',cursive; font-size:1rem; padding:5px 16px; border-radius:50px; }
  .quiz-pergunta { font-size:1.15rem; font-weight:800; color:var(--dark); text-align:center; margin-bottom:20px; line-height:1.4; }
  .quiz-categoria { display:inline-block; margin-top:6px; font-size:.85rem; font-weight:800; color:white; padding:4px 14px; border-radius:50px; }
  .opcoes { display:flex; flex-direction:column; gap:10px; margin-bottom:20px; }
  .opcao-btn {
    font-family:'Nunito',sans-serif; font-size:.97rem; font-weight:700;
    padding:13px 18px; border-radius:14px; border:3px solid #e8e8e8;
    background:white; color:var(--dark); cursor:pointer; text-align:left;
    transition:all .15s; line-height:1.3;
  }
  .opcao-btn:hover:not(:disabled) { border-color:var(--tab1); background:#fff8f0; transform:translateX(4px); }
  .opcao-btn.correta { background:#d4f7e7; border-color:#06D6A0; color:#0a5c3a; }
  .opcao-btn.errada  { background:#fde8e8; border-color:#EF476F; color:#7a1a2e; }
  .opcao-btn:disabled { cursor:default; transform:none; }
  .feedback-box { border-radius:14px; padding:12px 16px; font-size:.92rem; font-weight:700; line-height:1.5; margin-bottom:16px; display:none; animation:fadeIn .25s; }
  .feedback-box.acerto { background:#d4f7e7; color:#0a5c3a; }
  .feedback-box.erro   { background:#fde8e8; color:#7a1a2e; }
  .feedback-box.show   { display:block; }
  .btn-proximo { font-family:'Fredoka One',cursive; font-size:1.1rem; width:100%; padding:14px; border:none; border-radius:14px; background:var(--tab1); color:white; cursor:pointer; box-shadow:0 4px 0 #c04a18; transition:all .15s; display:none; }
  .btn-proximo:hover { transform:translateY(-2px); }
  .btn-proximo.show { display:block; animation:fadeIn .2s; }
  .resultado-shell { background:white; border-radius:24px; padding:32px 24px; box-shadow:0 6px 0 rgba(0,0,0,.08); text-align:center; }
  .resultado-emoji { font-size:4rem; margin-bottom:8px; }
  .resultado-titulo { font-family:'Fredoka One',cursive; font-size:1.8rem; color:var(--dark); margin-bottom:6px; }
  .resultado-placar { font-size:3rem; font-family:'Fredoka One',cursive; color:var(--tab1); margin:10px 0 4px; }
  .resultado-sub { font-size:.9rem; color:#888; font-weight:600; margin-bottom:24px; }
  .btn-reiniciar { font-family:'Fredoka One',cursive; font-size:1.05rem; padding:13px 28px; border:none; border-radius:50px; background:var(--tab1); color:white; cursor:pointer; box-shadow:0 4px 0 #c04a18; transition:all .15s; margin-bottom:28px; }
  .btn-reiniciar:hover { transform:translateY(-2px); }
  .revisao-titulo { font-family:'Fredoka One',cursive; font-size:1.2rem; color:var(--dark); margin-bottom:14px; text-align:left; }
  .revisao-card { background:#fff8f0; border-radius:16px; padding:16px 18px; margin-bottom:10px; text-align:left; border-left:5px solid var(--tab1); }
  .revisao-word { font-family:'Fredoka One',cursive; font-size:1.1rem; color:var(--dark); margin-bottom:6px; }
  .revisao-resp { font-size:.88rem; font-weight:700; color:#444; margin-bottom:3px; }
  .revisao-resp span { color:var(--tab1); }

  /* ════════════════════════
     RESUMO
  ════════════════════════ */
  .resumo-controles { background:white; border-radius:20px; padding:24px; margin-bottom:24px; box-shadow:0 4px 0 rgba(0,0,0,.07); }
  .resumo-controles h3 { font-family:'Fredoka One',cursive; font-size:1.1rem; color:var(--dark); margin-bottom:14px; }
  .check-lista { display:flex; flex-direction:column; gap:10px; margin-bottom:20px; }
  .check-item { display:flex; align-items:center; gap:10px; font-weight:700; font-size:.95rem; color:var(--dark); cursor:pointer; }
  .check-item input[type=checkbox] { width:20px; height:20px; cursor:pointer; accent-color:var(--tab1); }
  .btn-imprimir { font-family:'Fredoka One',cursive; font-size:1.05rem; padding:13px 28px; border:none; border-radius:50px; background:var(--tab1); color:white; cursor:pointer; box-shadow:0 4px 0 #c04a18; transition:all .15s; }
  .btn-imprimir:hover { transform:translateY(-2px); }
  .resumo-preview { background:white; border-radius:20px; padding:32px; box-shadow:0 4px 0 rgba(0,0,0,.07); font-size:.92rem; color:#222; line-height:1.8; }
  .resumo-preview h2 { font-family:'Fredoka One',cursive; font-size:1.4rem; color:var(--dark); margin:0 0 6px; border-bottom:3px solid var(--tab1); padding-bottom:6px; }
  .resumo-preview h3 { font-family:'Fredoka One',cursive; font-size:1.1rem; color:var(--tab1); margin:20px 0 6px; }
  .resumo-preview p { margin-bottom:8px; }
  .resumo-preview ul { padding-left:20px; margin-bottom:8px; }
  .resumo-preview li { margin-bottom:4px; }

  /* ════════════════════════
     QUIZ ARCADE
  ════════════════════════ */
  .quiz-config {
    background: white; border-radius: 22px;
    padding: 26px 24px; box-shadow: 0 5px 0 rgba(0,0,0,.08);
    margin-bottom: 20px;
  }
  .quiz-config h3 {
    font-family: 'Fredoka One', cursive; font-size: 1.1rem;
    color: var(--dark); margin-bottom: 16px;
  }
  .config-opcoes {
    display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 22px;
  }
  .config-check {
    display: flex; align-items: center; gap: 8px;
    font-weight: 700; font-size: .95rem; color: var(--dark); cursor: pointer;
    background: #f5f5f5; padding: 10px 16px; border-radius: 50px;
    border: 2px solid transparent; transition: all .15s;
  }
  .config-check:has(input:checked) { background: #fff3ec; border-color: var(--tab1); }
  .config-check input { width: 17px; height: 17px; accent-color: var(--tab1); cursor: pointer; }
  .btn-comecar {
    font-family: 'Fredoka One', cursive; font-size: 1.1rem;
    padding: 14px 32px; border: none; border-radius: 50px;
    background: var(--roxo); color: white; cursor: pointer;
    box-shadow: 0 4px 0 #5a3a8a; transition: all .15s; display: block; width: 100%;
  }
  .btn-comecar:hover { transform: translateY(-2px); }
  .btn-comecar:disabled { opacity: .4; cursor: not-allowed; transform: none; }

  /* arena do jogo */
  .quiz-arena {
    background: var(--dark); border-radius: 22px;
    padding: 20px 16px; box-shadow: 0 6px 0 rgba(0,0,0,.25);
    overflow: hidden; position: relative;
    max-width: 480px; margin: 0 auto;
  }
  .arena-topo {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 14px;
  }
  .arena-score {
    font-family: 'Fredoka One', cursive; font-size: 1rem;
    color: var(--amarelo);
  }
  .arena-nivel {
    font-size: .8rem; font-weight: 800; color: rgba(255,255,255,.5);
  }
  .arena-prog {
    height: 6px; background: rgba(255,255,255,.1); border-radius: 50px;
    margin-bottom: 16px; overflow: hidden;
  }
  .arena-prog-fill {
    height: 100%; border-radius: 50px;
    background: linear-gradient(90deg, var(--tab1), var(--roxo));
    transition: width .3s;
  }

  /* trilho de animação */
  .trilho {
    height: 90px; background: rgba(255,255,255,.04);
    border-radius: 16px; position: relative; overflow: hidden;
    margin-bottom: 16px; border: 2px solid rgba(255,255,255,.08);
  }
  .operacao-tag {
    position: absolute; top: 50%; transform: translateY(-50%);
    font-family: 'Fredoka One', cursive; font-size: 1.8rem;
    color: white; white-space: nowrap;
    text-shadow: 0 0 20px rgba(255,255,255,.3);
    animation-name: slide-tag;
    animation-timing-function: linear;
    animation-fill-mode: forwards;
  }
  @keyframes slide-tag {
    from { left: -5%; }
    to   { left: 105%; }
  }

  /* barra de tempo */
  .tempo-wrap {
    height: 10px; background: rgba(255,255,255,.08);
    border-radius: 50px; margin-bottom: 18px; overflow: hidden;
  }
  .tempo-fill {
    height: 100%; border-radius: 50px;
    background: linear-gradient(90deg, #06D6A0, #FFD93D);
    transition: width .1s linear;
  }
  .tempo-fill.urgente { background: linear-gradient(90deg, #EF476F, #FF6B35); }

  /* botões correto / incorreto */
  .arena-botoes {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
  }
  .btn-vf {
    font-family: 'Fredoka One', cursive; font-size: 1.3rem;
    padding: 18px; border: none; border-radius: 16px;
    cursor: pointer; transition: all .15s;
    box-shadow: 0 5px 0;
  }
  .btn-vf:hover:not(:disabled) { transform: translateY(-3px); }
  .btn-vf:disabled { opacity: .4; cursor: default; transform: none; }
  .btn-certo   { background: #06D6A0; color: white; box-shadow-color: #049c74; box-shadow: 0 5px 0 #049c74; }
  .btn-errado  { background: #EF476F; color: white; box-shadow: 0 5px 0 #b52e4f; }

  /* feedback flash */
  .arena-feedback {
    position: absolute; inset: 0; border-radius: 22px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Fredoka One', cursive; font-size: 2.5rem;
    pointer-events: none; opacity: 0; transition: opacity .15s;
    z-index: 10;
  }
  .arena-feedback.show { opacity: 1; }
  .arena-feedback.acerto { background: rgba(6,214,160,.25); }
  .arena-feedback.erro   { background: rgba(239,71,111,.25); }

  .arena-cronometro {
    font-family: 'Fredoka One', cursive; font-size: 2.2rem;
    color: white; min-width: 60px; text-align: center;
    line-height: 1;
  }
  .arena-cronometro.urgente { color: #EF476F; animation: piscar .4s infinite alternate; }
  @keyframes piscar { from { opacity:1; } to { opacity:.4; } }
  .arena-velocidade {
    font-size: .78rem; font-weight: 800; color: rgba(255,255,255,.5);
  }
  .arena-vidas {
    font-size: 1.1rem; letter-spacing: 2px;
  }
  .btn-zerar {
    font-family: 'Fredoka One', cursive; font-size: .85rem;
    background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
    color: rgba(255,255,255,.5); padding: 7px 16px; border-radius: 50px;
    cursor: pointer; margin-top: 12px; display: block; width: 100%;
    transition: all .2s;
  }
  .btn-zerar:hover { background: rgba(255,255,255,.16); color: white; }

  /* resultado */
  .resultado-shell { background:white; border-radius:24px; padding:32px 24px; box-shadow:0 6px 0 rgba(0,0,0,.08); text-align:center; }
  .resultado-emoji { font-size:4rem; margin-bottom:8px; }
  .resultado-titulo { font-family:'Fredoka One',cursive; font-size:1.8rem; color:var(--dark); margin-bottom:6px; }
  .resultado-placar { font-size:3rem; font-family:'Fredoka One',cursive; color:var(--tab1); margin:10px 0 4px; }
  .resultado-sub { font-size:.9rem; color:#888; font-weight:600; margin-bottom:24px; }
  .btn-reiniciar { font-family:'Fredoka One',cursive; font-size:1.05rem; padding:13px 28px; border:none; border-radius:50px; background:var(--roxo); color:white; cursor:pointer; box-shadow:0 4px 0 #5a3a8a; transition:all .15s; margin-bottom:28px; }
  .btn-reiniciar:hover { transform:translateY(-2px); }
  .revisao-titulo { font-family:'Fredoka One',cursive; font-size:1.15rem; color:var(--dark); margin-bottom:12px; text-align:left; }
  .revisao-card { background:#fff8f0; border-radius:14px; padding:14px 16px; margin-bottom:10px; text-align:left; border-left:5px solid var(--tab1); font-size:.9rem; font-weight:700; }

  @media print {
    body * { visibility:hidden; }
    .area-impressao, .area-impressao * { visibility:visible; }
    .area-impressao { position:fixed; top:0; left:0; width:100%; padding:24px 32px; font-family:Arial,sans-serif; font-size:11pt; color:#000; line-height:1.7; }
    .area-impressao h1 { font-size:16pt; text-align:center; border-bottom:2px solid #000; padding-bottom:6px; margin-bottom:16px; }
    .area-impressao h2 { font-size:13pt; margin:18px 0 4px; border-bottom:1px solid #ccc; padding-bottom:3px; }
    .area-impressao h3 { font-size:11pt; margin:12px 0 2px; }
    .area-impressao p, .area-impressao li { font-size:10.5pt; }
    .area-impressao ul { padding-left:18px; }
    .area-impressao table { width:100%; border-collapse:collapse; font-size:10pt; margin:8px 0; }
    .area-impressao th { background:#eee!important; padding:6px 10px; text-align:left; }
    .area-impressao td { padding:5px 10px; border-bottom:1px solid #eee; }
    .area-impressao .rodape-impressao { margin-top:32px; font-size:8pt; color:#999; text-align:center; border-top:1px solid #eee; padding-top:8px; }
  }

  @media(max-width:500px) {
    header h1 { font-size:1.5rem; }
    .tabuada-grid { grid-template-columns: repeat(2,1fr); }
    .resultado-placar { font-size:2.4rem; }
  }
</style>
</head>
<body>

<a class="btn-home" href="index.html">← Home</a>

<header>
  <h1>🔢 Flash Cards de Matemática</h1>
  <p>Tabuada · Algarismos Romanos · 4º Ano</p>
</header>

<div class="tabs">
  <button class="tab-btn active" data-tab="tabuada">✖️ Tabuada</button>
  <button class="tab-btn" data-tab="romanos">🏛️ Algarismos Romanos</button>
  <button class="tab-btn" data-tab="quiz">⭐ Quiz</button>
  <button class="tab-btn" data-tab="resumo">🖨️ Resumo</button>
</div>

<!-- ══════════════════════════════════════
     TAB 1 — TABUADA
══════════════════════════════════════ -->
